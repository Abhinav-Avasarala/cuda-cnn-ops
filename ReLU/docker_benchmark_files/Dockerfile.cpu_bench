FROM ubuntu:24.04

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      build-essential && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /work
COPY ReLU /work/ReLU

WORKDIR /work/ReLU/docker_benchmark_files
RUN make clean && make bench

# Usage:
#   docker run --rm cpu-relu-bench            # OpenMP default threads
#   docker run --rm cpu-relu-bench 8 20 5     # threads=8, iters=20, warmup=5
ENTRYPOINT ["./bin/bench_cpu_relu"]
